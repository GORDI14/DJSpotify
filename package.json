{
  "name": "smart-dj-for-spotify",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run start --workspace frontend\"",
    "dev:frontend": "npm run start --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "android": "npm run android --workspace frontend",
    "ios": "npm run ios --workspace frontend",
    "prebuild": "npm run prebuild --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
